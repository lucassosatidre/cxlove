  {
    "type": "function",
    "data": {
      "name": "consultar_monte_do_seu_jeito",
      "description": "Calcula o subtotal para 1 pizza avulsa Monte do Seu Jeito. Grande (R$ 67,00 base, 2 partes salgadas), gigante (R$ 87,00 base, 3 partes salgadas) ou broto (R$ 57,00 base, 1 sabor — salgado OU doce). Grande/gigante podem ter bebida promocional 1,5L por R$ 7,00. Broto usa bebida em preço avulso.",
      "parameters": {
        "type": "object",
        "properties": {
          "tamanho": {
            "type": "string",
            "enum": [
              "broto",
              "grande",
              "gigante"
            ]
          },
          "sabores": {
            "type": "array",
            "minItems": 1,
            "maxItems": 3,
            "items": {
              "type": "string"
            },
            "description": "Sabores. Broto: 1 sabor (salgado ou doce). Grande: 2 partes (salgado). Gigante: 3 partes (salgado). Repita sabor para pizza inteira."
          },
          "tipo_broto": {
            "type": "string",
            "enum": [
              "salgada",
              "doce",
              "nao_aplica"
            ],
            "description": "Use 'salgada' ou 'doce' se tamanho=broto. Senão 'nao_aplica'."
          },
          "borda": {
            "type": "boolean",
            "description": "Adicionar borda. Broto R$ 16, Grande R$ 18, Gigante R$ 20."
          },
          "bebida_promocional": {
            "type": "string",
            "enum": [
              "nenhuma",
              "Coca Cola 1,5L",
              "Coca Cola Zero 1,5L",
              "Guaraná Antarctica 1,5L",
              "Guaraná Antarctica Zero 1,5L"
            ],
            "description": "Refrigerante 1,5L por R$ 7,00. Só válido com grande ou gigante."
          },
          "bebida_avulsa": {
            "type": "string",
            "enum": [
              "nenhuma",
              "Heineken Longneck Zero 330ml",
              "Heineken Longneck 330ml",
              "Água Mineral 500ml",
              "Água com Gás 1,5L",
              "Guaraná Antarctica 1,5L",
              "Guaraná Antarctica Zero 1,5L",
              "Coca Cola 1,5L",
              "Coca Cola Zero 1,5L"
            ],
            "description": "Bebida em preço avulso (para broto, ou bebida adicional em grande/gigante)."
          }
        },
        "required": [
          "tamanho",
          "sabores",
          "tipo_broto",
          "borda",
          "bebida_promocional",
          "bebida_avulsa"
        ]
      }
    }
  },
  {
    "type": "function",
    "data": {
      "name": "consultar_bebida_avulsa",
      "description": "Retorna o preço de uma bebida avulsa.",
      "parameters": {
        "type": "object",
        "properties": {
          "bebida": {
            "type": "string",
            "enum": [
              "Heineken Longneck Zero 330ml",
              "Heineken Longneck 330ml",
              "Água Mineral 500ml",
              "Água com Gás 1,5L",
              "Guaraná Antarctica 1,5L",
              "Guaraná Antarctica Zero 1,5L",
              "Coca Cola 1,5L",
              "Coca Cola Zero 1,5L"
            ]
          },
          "quantidade": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20,
            "default": 1
          }
        },
        "required": [
          "bebida",
          "quantidade"
        ]
      }
    }
  },
